		"fmt": "yarn format",
		"prepare": "husky"
	},
	"type": "module",
	"devDependencies": {
		"@biomejs/biome": "2.2.0",
		"@types/node": "^24.3.0",
		"husky": "^9.1.7",
		"lint-staged": "^16.1.5",
		"typescript": "^5.9.2"
	},
	"dependencies": {
		"kleur": "^4.1.5",
		"yaml": "^2.8.1"
	},
	"engines": {
		"node": ">=20.0.0"
	},
	"packageManager": "yarn@4.9.2",
	"lint-staged": {
		"*": [
			"biome check --write --no-errors-on-unmatched --files-ignore-unknown=true"
		]
	}
